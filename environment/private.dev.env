# Development Environment Configuration
# This file contains development-specific environment variables

# Server Configuration
NODE_ENV=development
PORT=3001
BASE_URL=http://localhost

# Database Configuration
MONGO_URI="mongodb+srv://root:Mockapi%40123@mockapicluster.v19bhc2.mongodb.net/smart_mock_api?retryWrites=true&w=majority"
DB_NAME=smart_mock_api

# JWT Configuration
PRIVATE_TOKEN_KEY=Ashutosh

# CORS Configuration (optional)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080,http://localhost:3002

# Logging Configuration (optional)
LOG_LEVEL=debug
LOG_FILE_MAX_SIZE=20m
LOG_FILE_MAX_FILES=14d


# Development Features
ENABLE_SWAGGER=true
ENABLE_DEBUG_ROUTES=true
ENABLE_QUERY_LOGGING=true

# Rate Limiting (Development - More Permissive)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Database Connection Pool (Development)
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000

# Session Configuration (Development)
SESSION_SECRET=dev-session-secret-key
SESSION_COOKIE_MAX_AGE=86400000

# Email Configuration (Development - Optional)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=dev@example.com
SMTP_PASS=dev-password

# Redis Configuration (Development - Optional)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Security Configuration (Development - Less Strict)
BCRYPT_ROUNDS=10
JWT_EXPIRY=24h
CORS_CREDENTIALS=true

# Monitoring and Analytics (Development)
ENABLE_METRICS=false
METRICS_PORT=9090

