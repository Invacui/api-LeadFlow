datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Corporation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  users     User[]
}

model User {
  id                   String        @id @default(auto()) @map("_id") @db.ObjectId
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  email                String        @unique
  name                 String
  passwordHash         String?
  role                 UserRole      @default(USER)
  isVerified           Boolean       @default(false)
  isDeleted            Boolean       @default(false)
  isSuspended          Boolean       @default(false)
  tokenBalance         Int           @default(0)
  emailVerifyToken     String?
  emailVerifyExpires   DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  refreshToken         String?
  corporationId        String        @db.ObjectId
  corporation          Corporation   @relation(fields: [corporationId], references: [id])
  leadRequests         LeadRequest[]
  templates            Template[]
  campaigns            Campaign[]
  conversations        Conversation[]
}

model LeadRequest {
  id           String             @id @default(auto()) @map("_id") @db.ObjectId
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  listName     String
  industry     Industry
  description  String?
  fileKey      String?
  cleanFileKey String?
  status       LeadStatus         @default(PENDING)
  totalCount   Int                @default(0)
  dupCount     Int                @default(0)
  isDeleted    Boolean            @default(false)
  userId       String             @db.ObjectId
  user         User               @relation(fields: [userId], references: [id])
  leads        Lead[]
  campaigns    CampaignLeadList[]
}

model Lead {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  email          String?
  phone          String?
  firstName      String?
  lastName       String?
  company        String?
  jobTitle       String?
  metadata       Json?
  leadRequestId  String         @db.ObjectId
  leadRequest    LeadRequest    @relation(fields: [leadRequestId], references: [id])
  engagementLogs EngagementLog[]
  conversation   Conversation?
}

model Template {
  id                 String         @id @default(auto()) @map("_id") @db.ObjectId
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  productName        String
  description        String
  targetAudience     String?
  tone               Tone           @default(PROFESSIONAL)
  cta                String?
  status             TemplateStatus @default(DRAFT)
  sampleEmailSubject String?
  sampleEmailBody    String?
  sampleWhatsApp     String?
  userId             String         @db.ObjectId
  user               User           @relation(fields: [userId], references: [id])
  campaigns          Campaign[]
}

model Campaign {
  id             String             @id @default(auto()) @map("_id") @db.ObjectId
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  name           String
  status         CampaignStatus     @default(PENDING)
  sentCount      Int                @default(0)
  repliedCount   Int                @default(0)
  hotLeadCount   Int                @default(0)
  tokenCost      Int                @default(0)
  userId         String             @db.ObjectId
  user           User               @relation(fields: [userId], references: [id])
  templateId     String             @db.ObjectId
  template       Template           @relation(fields: [templateId], references: [id])
  leadLists      CampaignLeadList[]
  engagementLogs EngagementLog[]
}

model CampaignLeadList {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  campaignId    String      @db.ObjectId
  campaign      Campaign    @relation(fields: [campaignId], references: [id])
  leadRequestId String      @db.ObjectId
  leadRequest   LeadRequest @relation(fields: [leadRequestId], references: [id])
}

model EngagementLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt  DateTime @default(now())
  campaignId String   @db.ObjectId
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  leadId     String   @db.ObjectId
  lead       Lead     @relation(fields: [leadId], references: [id])
  channel    Channel
  direction  Direction
  content    String
  status     String?
}

model Conversation {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  channel     Channel
  status      ConversationStatus @default(COLD)
  meetingLink String?
  leadId      String             @unique @db.ObjectId
  lead        Lead               @relation(fields: [leadId], references: [id])
  userId      String             @db.ObjectId
  user        User               @relation(fields: [userId], references: [id])
  messages    Message[]
}

model Message {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  createdAt      DateTime     @default(now())
  direction      Direction
  content        String
  isAiGenerated  Boolean      @default(false)
  conversationId String       @db.ObjectId
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

enum UserRole {
  ADMIN
  USER
}

enum Industry {
  EDTECH
  PHARMACEUTICAL
  REALESTATE
  FINTECH
  HEALTHCARE
  SAAS
  MANUFACTURING
  RETAIL
  LOGISTICS
  HOSPITALITY
  LEGAL
  AUTOMOTIVE
  TELECOM
  MEDIA
  NGO
  CONSULTING
  OTHER
}

enum LeadStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum TemplateStatus {
  DRAFT
  ACTIVE
}

enum CampaignStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

enum Tone {
  PROFESSIONAL
  CASUAL
  URGENT
  FRIENDLY
}

enum Channel {
  EMAIL
  WHATSAPP
}

enum Direction {
  OUTBOUND
  INBOUND
}

enum ConversationStatus {
  COLD
  WARM
  HOT
}
